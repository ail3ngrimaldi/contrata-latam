# Get both values from https://dashboard.privy.io → your app → Settings → API Keys
VITE_PRIVY_APP_ID=your-privy-app-id
VITE_PRIVY_CLIENT_ID=your-privy-client-id

# Solana
VITE_SOLANA_RPC=https://api.devnet.solana.com
# Run smart-contract/scripts/initialize.ts once to get this value
VITE_CONFIG_PDA=your-config-pda
# Devnet USDC mint (Circle's faucet: https://faucet.circle.com)
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Backend judge API — set to your deployed API URL in production
VITE_API_URL=http://localhost:3001
